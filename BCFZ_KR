<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Bombeiro Civil - Palestra Educacional</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 0;
      background: #0f172a;
      color: #fff;
    }
    header {
      background: linear-gradient(90deg, #dc2626, #7f1d1d);
      padding: 30px;
      text-align: center;
      font-size: 2em;
      font-weight: bold;
      letter-spacing: 2px;
    }
    .container {
      padding: 20px;
    }
    .form {
      margin-bottom: 20px;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    input, textarea, button {
      padding: 10px;
      border-radius: 8px;
      border: none;
      font-size: 1em;
    }
    button {
      background: #dc2626;
      color: white;
      cursor: pointer;
      transition: 0.3s;
    }
    button:hover {
      background: #b91c1c;
    }
    .gallery {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
      gap: 20px;
    }
    .card {
      background: #1e293b;
      border-radius: 15px;
      overflow: hidden;
      box-shadow: 0 4px 10px rgba(0,0,0,0.5);
      transition: transform 0.3s;
    }
    .card:hover {
      transform: scale(1.05);
    }
    .card img {
      width: 100%;
      height: 200px;
      object-fit: cover;
    }
    .card .content {
      padding: 10px;
    }
  </style>
</head>
<body>

<header>
  🚒 Bombeiro Civil
</header>

<div class="container">

  <div class="form">
    <input type="file" id="imageInput" accept="image/*">
    <input type="text" id="titleInput" placeholder="Título da imagem">
    <textarea id="descInput" placeholder="Descrição..."></textarea>
    <button onclick="addPhoto()">Adicionar à Galeria</button>
  </div>

  <div class="gallery" id="gallery"></div>

</div>

<script>
  function addPhoto() {
    const file = document.getElementById('imageInput').files[0];
    const title = document.getElementById('titleInput').value;
    const desc = document.getElementById('descInput').value;

    if (!file) {
      alert('Selecione uma imagem!');
      return;
    }

    const reader = new FileReader();
    reader.onload = function(e) {
      const gallery = document.getElementById('gallery');

      const card = document.createElement('div');
      card.className = 'card';

      card.innerHTML = `
        <img src="${e.target.result}">
        <div class="content">
          <h3>${title}</h3>
          <p>${desc}</p>
        </div>
      `;

      gallery.prepend(card);
    };

    reader.readAsDataURL(file);

    // Limpar campos
    document.getElementById('imageInput').value = '';
    document.getElementById('titleInput').value = '';
    document.getElementById('descInput').value = '';
  }
</script>

</body>
</html>
